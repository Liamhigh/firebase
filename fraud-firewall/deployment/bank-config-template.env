# ============================================================================
# VERUM OMNIS FRAUD FIREWALL — BANK SERVER CONFIGURATION
# ============================================================================
#
# This file configures the Fraud Firewall for your bank's deployment.
# Copy this template to /opt/verum-firewall/.env and customize for your
# institution.
#
# SECURITY NOTE: This file contains sensitive configuration. Restrict access:
#   chmod 600 /opt/verum-firewall/.env
#
# ============================================================================

# INSTITUTION IDENTIFICATION
# ============================================================================
INSTITUTION_NAME=My Bank Name
INSTITUTION_ID=bank-001
JURISDICTION=ZA
COUNTRY_CODE=ZA

# FIREWALL DIRECTORIES
# ============================================================================
# Must have read/write permissions and sufficient disk space.
# Evidence vault is NOT transmitted to Verum — remains on-premises only.

FIREWALL_MODELS_DIR=/opt/verum-firewall/models
FIREWALL_VAULT_DIR=/opt/verum-firewall/vault

# API & PORT CONFIGURATION
# ============================================================================
# Port must be accessible to your internal banking system.
# Recommend: Do NOT expose to public internet.

FIREWALL_PORT=8787
API_LOG_LEVEL=info

# CONTACT INFORMATION
# ============================================================================
# Emails for fraud alerts and regulatory notifications.

FRAUD_DEPARTMENT_EMAIL=fraud-detection@mybank.com
SUPPORT_EMAIL=firewall-support@mybank.com
FRAUD_ANALYST_EMAIL=analyst@mybank.com

# CONSTITUTION & COMPLIANCE
# ============================================================================
# Constitution v6.0.0 is embedded in the deployment package.
# DO NOT MODIFY.

CONSTITUTION_VERSION=6.0.0
COMPLIANCE_FRAMEWORK=SA_CONSTITUTIONAL_COURT

# TRANSACTION MONITORING THRESHOLDS
# ============================================================================
# Adjust these based on your institution's risk profile.
# All amounts in ZAR (South African Rand).

AMOUNT_THRESHOLD_ZAR=50000
SUSPICIOUS_PATTERN_THRESHOLD=0.65
HIGH_RISK_COUNTRY_CODES=KP,IR,SY,CU

# MISTRAL AGENT CONFIGURATION
# ============================================================================
# Real-time fraud prevention agents with transaction blocking authority.
#
# BLOCKING AUTHORITIES:
#   - TransactionMonitor: Can block transactions + halt payments
#   - AccountProfiler: Can block accounts (no payment halting)
#   - CommunicationAudit: Can block fraud indicators + halt payments

MISTRAL_ENABLE_BLOCKING=true
MISTRAL_BLOCKING_ALERT_THRESHOLD=0.7
MISTRAL_AUTO_REVERSAL_ENABLED=false
MISTRAL_BLOCKING_LOG_LEVEL=debug

# EXTERNAL DATA CONNECTORS (OPTIONAL)
# ============================================================================
# Allow Mistral agents to check news services, court databases, regulatory
# feeds for fraud pattern updates. Requires internet access.
#
# NOTE: No customer data, transaction details, or internal PII is transmitted.
#       Only fraud pattern hashes and signature verification queries.

ENABLE_EXTERNAL_DATA=false
NEWS_API_KEY=
COURT_RECORDS_API_KEY=
REGULATORY_FEED_URL=

# COMMISSION & FINANCIAL
# ============================================================================
# Verum Omnis commission is HARD-CODED at 20%.
# DO NOT MODIFY — enforced at code level.

VERUM_COMMISSION_PERCENT=20
VERUM_COMMISSION_EMAIL=fraud-commission@verum.example.com
VERUM_VERIFY_URL=https://www.verumglobal.foundation/verify

# BLOCKCHAIN ANCHORING
# ============================================================================
# Evidence is sealed via SHA-512 and anchored to Bitcoin blockchain
# using OpenTimestamps service.
#
# ANCHOR_MODE:
#   - offline:  Seals locally, submits when internet available
#   - online:   Immediate Bitcoin anchoring (requires internet)

ANCHOR_MODE=offline
OPENTIMESTAMPS_SERVER=https://a.opentimestamps.org

# AUDIT & COMPLIANCE LOGGING
# ============================================================================
# All actions logged to immutable audit trail in vault.
# GPS location recorded for jurisdiction tracking.

GPS_ENABLED=true
AUDIT_LOG_ROTATION=daily
AUDIT_RETENTION_DAYS=2555

# SECURITY & AUTHENTICATION
# ============================================================================
# For MVP: admin-key (recommended: generate strong random key)
# For production: JWT/OAuth with institutional tokens
#
# Generate secure key:
#   openssl rand -hex 32

ADMIN_KEY=demo-admin-key-12345
# ADMIN_KEY=your-secure-random-key-here

# NOTIFICATION & EMAIL
# ============================================================================
# Emails are persisted locally for SMTP/mailer integration.
# No emails transmitted automatically — review and approve before sending.

NOTIFICATION_STORAGE=/opt/verum-firewall/vault/outbound-email
SMTP_HOOK_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# DEBUG & DEVELOPMENT
# ============================================================================
# ONLY for testing — disable in production.

DEBUG=false
TRACE_REQUESTS=false
DUMP_TRANSACTIONS=false

# ============================================================================
# VERIFICATION CHECKLIST
# ============================================================================
# Before deployment, verify:
#
# [ ] INSTITUTION_NAME configured correctly
# [ ] JURISDICTION matches your regulatory body
# [ ] FRAUD_DEPARTMENT_EMAIL is reachable
# [ ] FIREWALL_VAULT_DIR has sufficient disk space (100GB+ recommended)
# [ ] FIREWALL_MODELS_DIR contains Gemma3, Gemma4, Mistral models
# [ ] FIREWALL_PORT is not in use by other services
# [ ] ADMIN_KEY is unique and secure
# [ ] Constitution v6.0.0 is embedded and verified
# [ ] Audit logging is writable
#
# ============================================================================
# DEPLOYMENT VERIFICATION COMMAND
# ============================================================================
#
# After configuration, run health check:
#
#   npm run health-check
#
# This verifies all directories, models, and compliance constraints.
# ============================================================================
