{
  "name": "@verum-omnis/fraud-firewall",
  "version": "5.2.7",
  "description": "Verum Omnis Guardian Fraud Firewall — enterprise on-premise fraud detection, sealing, and commission system under Constitution v5.2.7",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vo-firewall": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/constitution && cp src/constitution/*.json dist/constitution/",
    "dev": "tsx watch src/cli.ts serve",
    "start": "node dist/cli.js serve",
    "demo": "tsx src/cli.ts demo",
    "test": "tsx --test tests/**/*.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
